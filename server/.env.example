# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Persistence ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/citeguard

# ── DeepSeek (OpenAI-compatible) ──────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── CROO / CAP ────────────────────────────────────────────────────────────
# Agent + service registration is done in the CROO Dashboard, not in code.
# The SDK-Key (croo_sk_...) and Service ID come from the Dashboard.
CAP_ENABLED=false
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=
CROO_SERVICE_ID=
BASE_RPC_URL=https://mainnet.base.org

# ── Capability ────────────────────────────────────────────────────────────
CAPABILITY_PRICE_USDC=0.50

# Comma-separated lowercase wallet addresses we control (self-trade guardrail).
OWN_WALLETS=

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ── Pipeline tuning ───────────────────────────────────────────────────────
MAX_CLAIMS=40
SOURCE_FETCH_TIMEOUT_MS=10000
SOURCE_CACHE_TTL_MS=86400000
