{
  "name": "citeguard-server",
  "version": "1.0.0",
  "description": "CiteGuard — output & citation verification agent backend for the CROO economy",
  "license": "MIT",
  "keywords": ["citeguard", "croo", "cap", "deepseek", "citation-verification"],
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --fix src test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.7.2",
    "morgan": "^1.10.1",
    "openai": "^6.45.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.38.0",
    "eslint-plugin-format": "^1.0.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  }
}
